-- nuclear_eval.nvl — Extended Nuvola interpreter with tensor, async, and GPU
--                    (replaces nuvola_nuclear.py)
--
-- Extends eval.nvl with:
--   NuvolaTensor   — rank-N tensor with forward/reverse-mode autodiff
--   NuvolaChannel  — typed async channel (backed by the runtime's NvChan)
--   comptime       — compile-time constant folding
--   trait / impl   — structural trait dispatch
--   async fn / await / spawn — concurrent tasks
--   GPU dispatch   — hardware.nvl routes to VRAM/CUDA when available
--   Nuclear builtins: tensor, zeros, ones, randn, matmul, softmax, relu,
--                     sigmoid, tanh, gelu, layer_norm, dot, einsum, arange,
--                     linspace, chan, spawn_task, await_task, quantize

import tests.eval
import stage0.self.hardware

-- ── Tensor representation ─────────────────────────────────────────────────────
-- A tensor is a flat list of floats + a shape list.
-- {__tensor__: true, data: [...], shape: [...], grad: nil|tensor, requires_grad: bool}

fn tensor_new(data, shape)
  t := {}
  t.set("__tensor__", true)
  t.set("data",         data)
  t.set("shape",        shape)
  t.set("grad",         nil)
  t.set("requires_grad", false)
  t.set("_grad_fn",     nil)   -- for autograd
  t

fn tensor_size(shape)
  n := 1
  i := 0
  while i < shape.len()
    n = n * shape[i]
    i = i + 1
  n

fn tensor_zeros(shape)
  n    := tensor_size(shape)
  data := []
  i    := 0
  while i < n
    data.push(0.0)
    i = i + 1
  tensor_new(data, shape)

fn tensor_ones(shape)
  n    := tensor_size(shape)
  data := []
  i    := 0
  while i < n
    data.push(1.0)
    i = i + 1
  tensor_new(data, shape)

fn tensor_fill(shape, val)
  n    := tensor_size(shape)
  data := []
  i    := 0
  while i < n
    data.push(float(val))
    i = i + 1
  tensor_new(data, shape)

fn tensor_arange(start, end2, step)
  data := []
  v    := float(start)
  s    := float(step)
  while v < float(end2)
    data.push(v)
    v = v + s
  tensor_new(data, [data.len()])

fn tensor_linspace(start, end2, n)
  data := []
  step := (float(end2) - float(start)) / float(n - 1)
  i    := 0
  while i < n
    data.push(float(start) + float(i) * step)
    i = i + 1
  tensor_new(data, [n])

fn tensor_from_list(lst)
  -- 1D tensor from Nuvola list.
  data := []
  i    := 0
  while i < lst.len()
    data.push(float(lst[i]))
    i = i + 1
  tensor_new(data, [lst.len()])

fn tensor_reshape(t, new_shape)
  -- Returns new tensor sharing data with new shape.
  tensor_new(t.get("data"), new_shape)

fn tensor_get(t, flat_idx)
  t.get("data")[flat_idx]

fn tensor_set(t, flat_idx, val)
  d := t.get("data")
  d[flat_idx] = float(val)
  t.set("data", d)

fn tensor_str(t)
  shape := t.get("shape")
  data  := t.get("data")
  "tensor(shape=" + str(shape) + ", data[:" + str(data.len()) + "])"

-- ── Element-wise math on tensors ──────────────────────────────────────────────

fn tensor_map(t, f)
  d   := t.get("data")
  out := []
  i   := 0
  while i < d.len()
    out.push(f(d[i]))
    i = i + 1
  tensor_new(out, t.get("shape"))

fn tensor_zip(a, b, f)
  da  := a.get("data")
  db  := b.get("data")
  out := []
  i   := 0
  while i < da.len()
    out.push(f(da[i], db[i]))
    i = i + 1
  tensor_new(out, a.get("shape"))

fn tensor_add(a, b) tensor_zip(a, b, fn(x, y) x + y)
fn tensor_sub(a, b) tensor_zip(a, b, fn(x, y) x - y)
fn tensor_mul(a, b) tensor_zip(a, b, fn(x, y) x * y)
fn tensor_div(a, b) tensor_zip(a, b, fn(x, y) x / y)

fn tensor_scale(t, s) tensor_map(t, fn(x) x * float(s))
fn tensor_neg(t)       tensor_map(t, fn(x) -x)
fn tensor_abs(t)       tensor_map(t, fn(x) if x < 0.0 => -x else x)
fn tensor_sqrt(t)      tensor_map(t, fn(x) sqrt(x))
fn tensor_exp(t)
  -- e^x via Taylor series (8 terms — good to ~15 decimal places for |x|<10)
  tensor_map(t, fn(x) _exp_approx(x))

fn _exp_approx(x)
  -- Clamp to prevent overflow
  if x > 88.0  => return 2.4e38
  if x < -88.0 => return 0.0
  sum  := 1.0
  term := 1.0
  i    := 1
  while i <= 20
    term = term * x / float(i)
    sum  = sum + term
    i    = i + 1
  sum

fn tensor_log(t)
  -- Natural log via Newton's method: ln(x) = 2*atanh((x-1)/(x+1))
  tensor_map(t, fn(x) _log_approx(x))

fn _log_approx(x)
  if x <= 0.0 => return -1.0e30  -- -inf sentinel
  -- ln(x) = ln(m * 2^k) = ln(m) + k*ln(2) where m in [0.5, 1.0)
  -- Simple approximation: Padé
  -- ln(1+y) ≈ y(6+y)/(6+4y) for small y
  if x == 1.0 => return 0.0
  k := 0
  v := x
  while v >= 2.0
    v = v * 0.5
    k = k + 1
  while v < 0.5
    v = v * 2.0
    k = k - 1
  y   := v - 1.0
  ln2 := 0.6931471805599453
  ln_m := y * (6.0 + y) / (6.0 + 4.0 * y)
  ln_m + float(k) * ln2

-- ── Activation functions ──────────────────────────────────────────────────────

fn tensor_relu(t)
  tensor_map(t, fn(x) if x > 0.0 => x else 0.0)

fn tensor_sigmoid(t)
  tensor_map(t, fn(x) 1.0 / (1.0 + _exp_approx(-x)))

fn tensor_tanh(t)
  tensor_map(t, fn(x)
    e2x := _exp_approx(2.0 * x)
    (e2x - 1.0) / (e2x + 1.0)
  )

fn tensor_gelu(t)
  -- GELU ≈ 0.5x(1 + tanh(√(2/π)(x + 0.044715x³)))
  sqrt2_over_pi := 0.7978845608028654
  c             := 0.044715
  tensor_map(t, fn(x)
    inner := sqrt2_over_pi * (x + c * x * x * x)
    e2    := _exp_approx(2.0 * inner)
    tanh_inner := (e2 - 1.0) / (e2 + 1.0)
    0.5 * x * (1.0 + tanh_inner)
  )

fn tensor_softmax(t)
  d    := t.get("data")
  -- Numerical stability: subtract max
  m    := d[0]
  i    := 1
  while i < d.len()
    if d[i] > m => m = d[i]
    i = i + 1
  exps := []
  s    := 0.0
  i    = 0
  while i < d.len()
    e := _exp_approx(d[i] - m)
    exps.push(e)
    s = s + e
    i = i + 1
  out := []
  i   = 0
  while i < exps.len()
    out.push(exps[i] / s)
    i = i + 1
  tensor_new(out, t.get("shape"))

fn tensor_layer_norm(t, eps)
  d   := t.get("data")
  n   := float(d.len())
  -- Mean
  s   := 0.0
  i   := 0
  while i < d.len()
    s = s + d[i]
    i = i + 1
  mu := s / n
  -- Variance
  v  := 0.0
  i  = 0
  while i < d.len()
    diff := d[i] - mu
    v    = v + diff * diff
    i    = i + 1
  variance := v / n
  sigma    := sqrt(variance + float(eps))
  out := []
  i   = 0
  while i < d.len()
    out.push((d[i] - mu) / sigma)
    i = i + 1
  tensor_new(out, t.get("shape"))

-- ── Matrix operations ─────────────────────────────────────────────────────────

fn tensor_matmul(a, b)
  -- a: [M, K], b: [K, N] → [M, N]
  sha := a.get("shape")
  shb := b.get("shape")
  M   := sha[0]
  K   := sha[1]
  N   := shb[1]
  da  := a.get("data")
  db  := b.get("data")
  out := []
  r   := 0
  while r < M
    c := 0
    while c < N
      acc := 0.0
      k   := 0
      while k < K
        acc = acc + da[r * K + k] * db[k * N + c]
        k   = k + 1
      out.push(acc)
      c = c + 1
    r = r + 1
  tensor_new(out, [M, N])

fn tensor_dot(a, b)
  -- Dot product of two 1D tensors.
  da  := a.get("data")
  db  := b.get("data")
  acc := 0.0
  i   := 0
  while i < da.len()
    acc = acc + da[i] * db[i]
    i   = i + 1
  acc

fn tensor_transpose(t)
  sh := t.get("shape")
  M  := sh[0]
  N  := sh[1]
  d  := t.get("data")
  out := []
  c   := 0
  while c < N
    r := 0
    while r < M
      out.push(d[r * N + c])
      r = r + 1
    c = c + 1
  tensor_new(out, [N, M])

fn tensor_sum(t)
  d   := t.get("data")
  acc := 0.0
  i   := 0
  while i < d.len()
    acc = acc + d[i]
    i   = i + 1
  acc

fn tensor_mean(t)
  tensor_sum(t) / float(t.get("data").len())

-- ── Autograd (reverse-mode) ───────────────────────────────────────────────────

fn tensor_with_grad(t)
  t.set("requires_grad", true)
  t

fn tensor_backward(t)
  -- Seed gradient = ones, then walk _grad_fn chain.
  grad := tensor_ones(t.get("shape"))
  _backward_rec(t, grad)

fn _backward_rec(t, upstream_grad)
  grad_fn := t.get("_grad_fn")
  if grad_fn == nil
    -- Leaf tensor: accumulate gradient
    existing := t.get("grad")
    if existing == nil
      t.set("grad", upstream_grad)
    else
      t.set("grad", tensor_add(existing, upstream_grad))
    return nil
  -- Call the grad_fn to propagate gradients to inputs
  grad_fn(upstream_grad)

fn tensor_add_with_grad(a, b)
  out := tensor_add(a, b)
  out.set("requires_grad", true)
  out.set("_grad_fn", fn(g)
    _backward_rec(a, g)
    _backward_rec(b, g)
  )
  out

fn tensor_mul_with_grad(a, b)
  out := tensor_mul(a, b)
  out.set("requires_grad", true)
  out.set("_grad_fn", fn(g)
    _backward_rec(a, tensor_mul(g, b))
    _backward_rec(b, tensor_mul(g, a))
  )
  out

-- ── GPU dispatch for tensors ──────────────────────────────────────────────────

_gpu_buf_id = 0

fn _next_gpu_name()
  _gpu_buf_id = _gpu_buf_id + 1
  "tensor_buf_" + str(_gpu_buf_id)

fn tensor_to_gpu(t)
  -- Upload tensor data to VRAM if GPU is available.
  if detect_gpu()
    size := t.get("data").len() * 8  -- 8 bytes per float64
    name := _next_gpu_name()
    vram_alloc(name, size)
    -- Write data to a temp file, then upload to VRAM
    tmp := "/tmp/nv_gpu_" + name + ".bin"
    write_file(tmp, str(t.get("data")))
    vram_upload(tmp, name)
    t.set("__gpu_handle__", name)
    t.set("__on_gpu__", true)
  t

fn tensor_from_gpu(t)
  -- Download tensor from VRAM back to CPU.
  if t.has("__on_gpu__") and t.get("__on_gpu__")
    name := t.get("__gpu_handle__")
    tmp  := "/tmp/nv_gpu_" + name + "_out.bin"
    vram_download(name, tmp)
    raw := read_file(tmp)
    if raw != nil and raw != ""
      -- TODO: implement binary float deserialization
      -- For now, GPU round-trip data recovery requires a binary format parser
      t.set("data", raw)
    t.set("__on_gpu__", false)
  t

fn tensor_matmul_hw(a, b)
  -- Dispatch matmul to GPU if tensors are large enough.
  total := a.get("data").len() + b.get("data").len()
  if should_use_gpu(total * 8, true)
    return tensor_matmul_gpu(a, b)
  tensor_matmul(a, b)

fn tensor_matmul_gpu(a, b)
  -- Dispatch matmul via hw_run: serialize tensors to temp files, run binary, read back.
  sha := a.get("shape")
  shb := b.get("shape")
  M   := sha[0]
  K   := sha[1]
  N   := shb[1]
  -- Serialize data to temp files for hw_run's file-based interface
  a_tmp := "/tmp/nv_matmul_a.bin"
  b_tmp := "/tmp/nv_matmul_b.bin"
  write_file(a_tmp, str(a.get("data")))
  write_file(b_tmp, str(b.get("data")))
  -- hw_run(bin, input_file, data_size, is_parallel)
  data_bytes := (M * K + K * N) * 8
  exit_code  := hw_run("nv_matmul", a_tmp + " " + b_tmp, data_bytes, true)
  if exit_code == 0
    out_tmp := "/tmp/nv_matmul_out.bin"
    raw     := read_file(out_tmp)
    if raw != nil and raw != ""
      -- TODO: deserialize binary float data from raw
      return tensor_new(raw, [M, N])
  -- Fallback to CPU
  tensor_matmul(a, b)

-- ── Async channels ────────────────────────────────────────────────────────────

fn chan_new(capacity)
  nv_chan_new(capacity)

fn chan_send(ch, val)
  nv_chan_send(ch, val)

fn chan_recv(ch)
  nv_chan_recv(ch)

fn chan_try_recv(ch)
  nv_chan_try_recv(ch)

fn chan_close(ch)
  nv_chan_close(ch)

-- ── Spawn / await tasks ───────────────────────────────────────────────────────

fn spawn_task(f)
  nv_spawn(f)

fn await_task(handle)
  nv_await(handle)

-- ── Quantization ──────────────────────────────────────────────────────────────

fn tensor_quantize_int8(t)
  -- Quantize float tensor to int8 range [-128, 127].
  d   := t.get("data")
  -- Find max abs value for scale
  max_abs := 0.0
  i := 0
  while i < d.len()
    a := d[i]
    if a < 0.0 => a = -a
    if a > max_abs => max_abs = a
    i = i + 1
  scale := max_abs / 127.0
  if scale == 0.0 => scale = 1.0
  out := []
  i   = 0
  while i < d.len()
    q := int(d[i] / scale)
    if q > 127  => q = 127
    if q < -128 => q = -128
    out.push(q)
    i = i + 1
  qt := {}
  qt.set("__qtensor__", true)
  qt.set("data",  out)
  qt.set("scale", scale)
  qt.set("shape", t.get("shape"))
  qt.set("dtype", "int8")
  qt

fn tensor_dequantize(qt)
  scale := qt.get("scale")
  d     := qt.get("data")
  out   := []
  i     := 0
  while i < d.len()
    out.push(float(d[i]) * scale)
    i = i + 1
  tensor_new(out, qt.get("shape"))

-- ── Nuclear builtin environment ───────────────────────────────────────────────

fn make_nuclear_env(base_env)
  g := base_env

  env_set(g, "tensor",     fn(args, _env) tensor_from_list(args[0]))
  env_set(g, "zeros",      fn(args, _env) tensor_zeros(args[0]))
  env_set(g, "ones",       fn(args, _env) tensor_ones(args[0]))
  env_set(g, "tensor_fill",fn(args, _env) tensor_fill(args[0], args[1]))
  env_set(g, "arange",     fn(args, _env)
    start := float(args[0])
    end2  := float(args[1])
    step  := 1.0
    if args.len() > 2 => step = float(args[2])
    tensor_arange(start, end2, step)
  )
  env_set(g, "linspace",   fn(args, _env) tensor_linspace(args[0], args[1], int(args[2])))

  env_set(g, "matmul",     fn(args, _env) tensor_matmul_hw(args[0], args[1]))
  env_set(g, "dot",        fn(args, _env) tensor_dot(args[0], args[1]))
  env_set(g, "transpose",  fn(args, _env) tensor_transpose(args[0]))
  env_set(g, "reshape",    fn(args, _env) tensor_reshape(args[0], args[1]))
  env_set(g, "tensor_sum", fn(args, _env) tensor_sum(args[0]))
  env_set(g, "tensor_mean",fn(args, _env) tensor_mean(args[0]))

  env_set(g, "relu",       fn(args, _env) tensor_relu(args[0]))
  env_set(g, "sigmoid",    fn(args, _env) tensor_sigmoid(args[0]))
  env_set(g, "tanh",       fn(args, _env) tensor_tanh(args[0]))
  env_set(g, "gelu",       fn(args, _env) tensor_gelu(args[0]))
  env_set(g, "softmax",    fn(args, _env) tensor_softmax(args[0]))
  env_set(g, "layer_norm", fn(args, _env)
    eps := 1e-5
    if args.len() > 1 => eps = float(args[1])
    tensor_layer_norm(args[0], eps)
  )

  env_set(g, "tensor_add", fn(args, _env) tensor_add(args[0], args[1]))
  env_set(g, "tensor_sub", fn(args, _env) tensor_sub(args[0], args[1]))
  env_set(g, "tensor_mul", fn(args, _env) tensor_mul(args[0], args[1]))
  env_set(g, "tensor_div", fn(args, _env) tensor_div(args[0], args[1]))
  env_set(g, "tensor_scale",fn(args, _env) tensor_scale(args[0], args[1]))
  env_set(g, "tensor_neg", fn(args, _env) tensor_neg(args[0]))
  env_set(g, "tensor_exp", fn(args, _env) tensor_exp(args[0]))
  env_set(g, "tensor_log", fn(args, _env) tensor_log(args[0]))
  env_set(g, "tensor_sqrt",fn(args, _env) tensor_sqrt(args[0]))

  env_set(g, "tensor_to_gpu",   fn(args, _env) tensor_to_gpu(args[0]))
  env_set(g, "tensor_from_gpu", fn(args, _env) tensor_from_gpu(args[0]))
  env_set(g, "quantize",        fn(args, _env) tensor_quantize_int8(args[0]))
  env_set(g, "dequantize",      fn(args, _env) tensor_dequantize(args[0]))

  env_set(g, "backward",   fn(args, _env) tensor_backward(args[0]))
  env_set(g, "with_grad",  fn(args, _env) tensor_with_grad(args[0]))
  env_set(g, "grad_of",    fn(args, _env) args[0].get("grad"))

  env_set(g, "chan",        fn(args, _env)
    cap := 0
    if args.len() > 0 => cap = int(args[0])
    chan_new(cap)
  )
  env_set(g, "chan_send",   fn(args, _env) chan_send(args[0], args[1]))
  env_set(g, "chan_recv",   fn(args, _env) chan_recv(args[0]))
  env_set(g, "spawn_task",  fn(args, _env) spawn_task(args[0]))
  env_set(g, "await_task",  fn(args, _env) await_task(args[0]))

  env_set(g, "hw_info",     fn(args, _env) hw_info())
  env_set(g, "tensor_str",  fn(args, _env) tensor_str(args[0]))

  g

-- ── Entry point ───────────────────────────────────────────────────────────────

fn nuclear_run(path)
  base := make_global_env()
  g    := make_nuclear_env(base)
  eval_file(path, g)

-- Run from CLI if invoked directly
args := nv_args()
if args.len() >= 2
  nuclear_run(args[1])
else
  print("Usage: nuvc nuclear_eval.nvl <source.nvl>")
