-- Benchmark 7: Hash map stress — 500K insert + 500K lookup
-- Tests: map performance, string key hashing

n := 500000
m := {}

-- Insert
i := 0
while i < n
  m.set("key_" + str(i), i * 7)
  i = i + 1

-- Lookup
sum := 0
i = 0
while i < n
  v := m.get("key_" + str(i))
  if v != nil
    sum = sum + 1
  i = i + 1

print("hashmap 500K insert+lookup, found=" + str(sum))
