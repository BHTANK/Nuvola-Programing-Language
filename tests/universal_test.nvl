-- § 14 — SELF-REFERENCE: COMPILER CAN CHECK ITSELF
-- ════════════════════════════════════════════════════════════════════════════
section_begin("Self-Reference")

-- Verify the compiler binary exists and can check a file
compiler := "stage0/self/a.out"
check(file_exists(compiler),     "compiler binary exists")
check(file_exists("build.nvl"),  "build.nvl exists")

-- Check this very file parses cleanly
check_out := popen_read(compiler + " check tests/universal_test.nvl 2>&1")
check(check_out.contains("nuvc: ok"), "compiler checks itself (universal_test.nvl)")

-- Check build.nvl parses cleanly
check_out2 := popen_read(compiler + " check build.nvl 2>&1")
check(check_out2.contains("nuvc: ok"), "compiler checks build.nvl")

-- Verify fixed-point: emit-c codegen.nvl twice, output should be identical
gen1_out := popen_read(compiler + " emit-c stage0/self/codegen.nvl 2>&1")
check(gen1_out.len > 10000, "emit-c codegen.nvl produces output")

section_end()

