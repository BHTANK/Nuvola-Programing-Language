assert(re_split(",", "a,b,c").len == 3,            "re_split")
assert(re_count("[0-9]", "a1b2c3") == 3,           "re_count")
assert(re_contains("[0-9]", "abc9xyz"),             "re_contains")
assert(not re_contains("[0-9]", "abcxyz"),          "re_contains false")

stripped := re_strip_html("<b>hello</b> <i>world</i>")
assert(stripped == "hello world", "re_strip_html")

nums := re_extract_numbers("price: 3.14, count: 7")
assert(nums.len >= 2, "re_extract_numbers count")

assert(re_is_email("user@example.com"),           "re_is_email valid")
assert(not re_is_email("notanemail"),              "re_is_email invalid")
assert(re_is_url("https://example.com"),           "re_is_url valid")
assert(not re_is_url("ftp://example.com"),         "re_is_url ftp false")
assert(re_is_int("42"),                            "re_is_int")
assert(re_is_int("-7"),                            "re_is_int neg")
assert(not re_is_int("3.14"),                      "re_is_int float false")
assert(re_is_float("3.14"),                        "re_is_float")
assert(re_is_float("-2.5e10"),                     "re_is_float sci")
assert(not re_is_float("abc"),                     "re_is_float alpha false")

print("PASS: regex helpers")

-- ─────────────────────────────────────────────────────────────────────────────
-- OS stdlib
-- ─────────────────────────────────────────────────────────────────────────────
import "std/os.nvl"

assert(os_basename("/foo/bar/baz.nvl") == "baz.nvl", "os_basename")
assert(os_basename("file.txt")         == "file.txt", "os_basename no dir")
assert(os_dirname("/foo/bar/baz.nvl")  == "/foo/bar", "os_dirname")
assert(os_dirname("file.txt")          == ".",         "os_dirname no dir")
assert(os_join("/tmp", "out.c")        == "/tmp/out.c", "os_join")
assert(os_join(".", "foo.nvl")         == "foo.nvl",    "os_join dot")
assert(os_ext("file.nvl")              == ".nvl",       "os_ext")
assert(os_ext("noext")                 == "",            "os_ext none")

cwd := os_getcwd()
assert(cwd.len > 0, "os_getcwd non-empty")

-- Write, read, check, remove a temp file
tmp_path := "/tmp/_nuvola_ft_test.txt"
write_file(tmp_path, "hello nuvola")
assert(os_exists(tmp_path),   "os_exists after write")
assert(os_is_file(tmp_path),  "os_is_file")
assert(not os_is_dir(tmp_path), "os_is_dir false")
assert(os_file_size(tmp_path) > 0, "os_file_size > 0")
os_remove(tmp_path)
assert(not os_exists(tmp_path), "os_exists after remove")

-- Env
home := os_getenv_default("HOME", "/tmp")
assert(home.len > 0, "os_getenv_default HOME")

print("PASS: os")

-- ─────────────────────────────────────────────────────────────────────────────
-- CLOSURES / HIGHER-ORDER FUNCTIONS
-- ─────────────────────────────────────────────────────────────────────────────

-- Closure capturing outer variable
fn make_adder(n)
  fn(x) => x + n

add5 := make_adder(5)
add10 := make_adder(10)
assert(add5(3)  == 8,  "closure add5")
assert(add10(3) == 13, "closure add10")

-- Closure mutating captured state via map
fn make_counter()
  state = {"n": 0}
  fn()
    state.set("n", state.get("n") + 1)
    state.get("n")

cnt := make_counter()
assert(cnt() == 1, "counter 1")
assert(cnt() == 2, "counter 2")
assert(cnt() == 3, "counter 3")

-- Function composition
fn compose(f, g)
  fn(x) => f(g(x))

double := fn(x) => x * 2
inc    := fn(x) => x + 1
double_then_inc := compose(inc, double)
assert(double_then_inc(4) == 9, "compose double+inc")

-- Placeholder lambda (identity and field)
nums2 := [1, 2, 3, 4, 5]
big_nums := filter(fn(x) => x > 3, nums2)
assert(big_nums.len == 2 and big_nums[0] == 4, "filter > 3")

sq := map(fn(x) => x * x, [1, 2, 3, 4])
assert(sq[0] == 1 and sq[3] == 16, "map square")

-- Currying via HOF
fn multiply_by(n)
  fn(x) => x * n

triple := multiply_by(3)
assert(triple(7) == 21, "curried triple")

print("PASS: closures/HOF")

-- ─────────────────────────────────────────────────────────────────────────────
-- STRUCTS AND ENUMS (type declarations)
-- ─────────────────────────────────────────────────────────────────────────────

type Point
  x: int
  y: int

type Size
  Small
  Medium
  Large

p := Point { x: 3, y: 4 }
assert(p.x == 3, "struct field x")
assert(p.y == 4, "struct field y")

p2 := Point { x: p.x + 1, y: p.y + 1 }
assert(p2.x == 4 and p2.y == 5, "struct field copy+modify")

-- Struct methods via function
type Vec3
  x: int
  y: int
  z: int

fn vec3_sum(v) => v.x + v.y + v.z

v1 := Vec3 { x: 1, y: 2, z: 3 }
assert(vec3_sum(v1) == 6, "struct method sum")

-- String-keyed "enum" via match (pattern from medium.nvl)
fn color_name(kind)
  match kind
    "red"   => "RED"
    "green" => "GREEN"
    "blue"  => "BLUE"
    _       => "UNKNOWN"

assert(color_name("red")   == "RED",     "color match red")
assert(color_name("green") == "GREEN",   "color match green")
assert(color_name("other") == "UNKNOWN", "color match fallback")

print("PASS: structs/enums")

-- ─────────────────────────────────────────────────────────────────────────────
-- MATCH EXPRESSIONS
-- ─────────────────────────────────────────────────────────────────────────────

fn classify(n)
  match n
    0         => "zero"
    1         => "one"
    2..=5     => "small"
    6..=99    => "medium"
    _         => "large"

assert(classify(0)   == "zero",   "match 0")
assert(classify(1)   == "one",    "match 1")
assert(classify(3)   == "small",  "match range 2..=5")
assert(classify(50)  == "medium", "match range 6..=99")
assert(classify(100) == "large",  "match wildcard")

-- Match guard (using if-else since binding guards not fully supported)
fn abs_val(n)
  if n >= 0 => return n
  -n

assert(abs_val(5)  == 5,  "abs pos")
assert(abs_val(-3) == 3,  "abs neg")
assert(abs_val(0)  == 0,  "abs zero")

-- Match on type (string)
fn type_label(v)
  t := type(v)
  match t
    "int"   => "integer"
    "float" => "decimal"
    "str"   => "text"
    "bool"  => "boolean"
    "nil"   => "nothing"
    _       => "other"

assert(type_label(42)    == "integer", "type match int")
assert(type_label(3.14)  == "decimal", "type match float")
assert(type_label("hi")  == "text",    "type match str")
assert(type_label(true)  == "boolean", "type match bool")
assert(type_label(nil)   == "nothing", "type match nil")

print("PASS: match")

-- ─────────────────────────────────────────────────────────────────────────────
-- DESTRUCTURING AND TUPLES
-- ─────────────────────────────────────────────────────────────────────────────

fn min_max(lst)
  lo = lst[0]
  hi = lst[0]
  for x in lst
    if x < lo => lo = x
    if x > hi => hi = x
  (lo, hi)

(lo, hi) := min_max([3, 1, 4, 1, 5, 9, 2, 6])
assert(lo == 1, "destructure min")
assert(hi == 9, "destructure max")

-- For-loop with map entries destructure
pair_map := {"a": 1, "b": 2, "c": 3}
pair_keys = []
for (k, v) in pair_map.entries()
  pair_keys.push(k)
assert(pair_keys.len == 3, "for destructure map entries count")

print("PASS: destructuring")

-- ─────────────────────────────────────────────────────────────────────────────
-- STRING INTERPOLATION
-- ─────────────────────────────────────────────────────────────────────────────

name2 := "Nuvola"
ver  := 1
s_interp := "Hello from {name2} v{ver}!"
assert(s_interp == "Hello from Nuvola v1!", "string interp simple")

x2 := 7
y2 := 3
s2 := "{x2} + {y2} = {x2 + y2}"
assert(s2 == "7 + 3 = 10", "string interp expr")

-- Nested expressions
items := [1, 2, 3]
s3 := "count={items.len} first={items[0]}"
assert(s3 == "count=3 first=1", "string interp method+index")

print("PASS: string interpolation")

