-- FINAL REPORT
-- ════════════════════════════════════════════════════════════════════════════
total_pass = 0
total_fail = 0
total_ms   = 0

print("")
print("══════════════════════════════════════════════════════════════")
print("  Nuvola Universal Standard Code Test — Results")
print("══════════════════════════════════════════════════════════════")

col_w = 36
for row in sections
  nm  := row.get("name")
  p   := row.get("passed")
  f   := row.get("failed")
  ms2 := row.get("ms")
  status := "PASS"
  if f > 0
    status = "FAIL"
  padded := str_pad_right(nm, col_w, " ")
  checks := str_pad_left(str(p + f), 3, " ") + " checks"
  timing := str_pad_left(str(ms2), 5, " ") + " ms"
  print("  " + padded + status + "  " + checks + "  " + timing)
  total_pass = total_pass + p
  total_fail = total_fail + f
  total_ms   = total_ms   + ms2

print("──────────────────────────────────────────────────────────────")
total_checks := total_pass + total_fail
print("  Total: " + str(total_pass) + "/" + str(total_checks) + " passed  (" + str(total_ms) + " ms)")
print("══════════════════════════════════════════════════════════════")

if total_fail == 0
  print("  ALL TESTS PASSED")
else
  print("  " + str(total_fail) + " TESTS FAILED")
